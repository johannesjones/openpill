# ---------------------------------------------------------------------------
# OpenPill example environment
# Copy to .env and adjust values for your setup.
# ---------------------------------------------------------------------------

# Core DB
MONGO_URI=mongodb://localhost:27017
OPENPILL_DB=knowledge_pills_db
OPENPILL_COLLECTION=knowledge_pills

# API auth (optional)
OPENPILL_API_KEY=

# Models (local-first defaults)
EMBEDDING_MODEL=ollama/nomic-embed-text
EXTRACTOR_MODEL=ollama/qwen2.5:7b
JANITOR_MODEL=ollama/qwen2.5:7b

# Optional external provider keys (only needed if you use cloud models)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Extractor model policy / escalation
# ---------------------------------------------------------------------------
EXTRACTOR_MODEL_POLICY=local_first
EXTRACTOR_EXTERNAL_MODEL=
EXTRACTOR_ESCALATION_ENABLED=false
EXTRACTOR_ESCALATION_MIN_TEXT_LEN=8000

# Same-source merge: if a near-duplicate matches source.reference (extractor:… / conversation:…), update existing pill
OPENPILL_MERGE_SAME_SOURCE=true

# ---------------------------------------------------------------------------
# Janitor model policy / escalation
# ---------------------------------------------------------------------------
JANITOR_MODEL_POLICY=local_first
JANITOR_EXTERNAL_MODEL=
JANITOR_ESCALATION_ENABLED=false
JANITOR_ESCALATION_MIN_GROUP_SIZE=6

# ---------------------------------------------------------------------------
# Hybrid retrieval pilot (safe default: off)
# ---------------------------------------------------------------------------
HYBRID_RETRIEVAL_ENABLED=false
HYBRID_VECTOR_WEIGHT=0.7
HYBRID_LEXICAL_WEIGHT=0.3
HYBRID_LEXICAL_LIMIT=30
HYBRID_LEXICAL_FALLBACK_MIN_VECTOR=3

# ---------------------------------------------------------------------------
# A/B runtime guards for external model usage
# ---------------------------------------------------------------------------
AB_GUARDS_ENABLED=false
AB_ALLOW_EXTERNAL=false
AB_MAX_EXTERNAL_CALLS=0

# A/B script guard (scripts/openclaw_model_ab_matrix.sh)
AB_ALLOW_EXTERNAL_AB=false
AB_MAX_COST_USD=

